rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: can read any profile, write only own
    match /users/{uid} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;

      match /private/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Posts: authenticated users can create; author can update/delete
    match /posts/{postId} {
      allow read: if true;

      // Any authenticated user can create a post
      allow create: if request.auth != null
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 50000;

      // Only the post author can edit content, delete, or change any other fields
      allow update: if request.auth != null
        && request.auth.uid == resource.data.authorId;

      // Any authenticated user can increment/decrement likes and views only
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likes', 'views', 'comments']);
    }

    // Comments: authenticated users can create; author can update/delete
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 5000;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.authorId;
    }

    // Likes: authenticated users can create/delete own
    match /likes/{likeId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Notifications: only the recipient can read; system writes via Admin
    match /notifications/{notifId} {
      allow read: if request.auth != null
        && resource.data.toUid == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && resource.data.toUid == request.auth.uid;
      allow delete: if false;
    }

    // Bookmarks: only the owner can read/write
    match /bookmarks/{bookmarkId} {
      allow read, write: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Reports: authenticated users can create
    match /reports/{reportId} {
      allow read: if false;
      allow create: if request.auth != null;
      allow delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
