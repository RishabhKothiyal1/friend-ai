{
  "entities": {
    "KeepNote": {
      "title": "KeepNote",
      "description": "A Google Keep style note stored in Firebase Firestore",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the note"
        },
        "content": {
          "type": "string",
          "description": "Content of the text note"
        },
        "color": {
          "type": "string",
          "description": "Pastel color background code class"
        },
        "pinned": {
          "type": "boolean",
          "description": "Whether the note is pinned to the top"
        },
        "tags": {
          "type": "array",
          "description": "List of tags associated with this note"
        },
        "type": {
          "type": "string",
          "enum": ["text", "checklist"],
          "description": "Type of the keep note"
        },
        "listItems": {
          "type": "array",
          "description": "Items in the checklist if the type is checklist"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp of when the note was last modified"
        }
      },
      "required": ["title", "type", "color", "pinned", "tags", "updatedAt"]
    }
  },
  "firestore": {
    "keep_notes": {
      "schema": {
        "$ref": "#/entities/KeepNote"
      },
      "description": "Google Keep notes synchronized across devices"
    }
  }
}
